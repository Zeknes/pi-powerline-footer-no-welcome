  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "powerline",
    "status-bar",
    "extension"
  ],
  "author": "Nico Bailon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicobailon/pi-powerline-footer.git"
  },
  "scripts": {
    "test": "node --experimental-strip-types --test tests/**/*.test.ts"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.74.0 <0.76.0",
    "@earendil-works/pi-coding-agent": ">=0.74.0 <0.76.0",
    "@earendil-works/pi-tui": ">=0.74.0 <0.76.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": ">=0.74.0 <0.76.0",
    "@earendil-works/pi-coding-agent": ">=0.74.0 <0.76.0",
    "@earendil-works/pi-tui": ">=0.74.0 <0.76.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
