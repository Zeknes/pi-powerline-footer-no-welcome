{
  "name": "pi-powerline-footer-no-welcome",
  "version": "0.5.6-local.0",
  "description": "Local fork of pi-powerline-footer with configurable startup welcome overlay",
  "type": "module",
  "files": [
    "*.ts",
    "*.md",
    "*.json",
    "!progress.md",
    "bash-mode/**/*.ts",
    "fixed-editor/**/*.ts"
